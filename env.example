# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=northwind
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/northwind

# --- LLM ---
LLM_PROVIDER=huggingface
HF_TOKEN=your_huggingface_token_here
