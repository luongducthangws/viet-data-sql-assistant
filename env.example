# Copy file nay thanh .env roi dien gia tri that
# cp .env.example .env

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=northwind
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/northwind

# --- LLM ---
LLM_PROVIDER=groq  # groq | gemini | openai | huggingface
HF_TOKEN=your_huggingface_token_here
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct:fastest
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
